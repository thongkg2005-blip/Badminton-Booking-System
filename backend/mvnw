#!/usr/bin/env bash
set -euo pipefail

# Lightweight Maven wrapper: downloads a specified Maven binary into .mvn/wrapper
MAVEN_VERSION="3.9.5"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_DIR="$SCRIPT_DIR/.mvn/wrapper"
MAVEN_DIR="$WRAPPER_DIR/apache-maven-$MAVEN_VERSION"

if [ ! -x "$MAVEN_DIR/bin/mvn" ]; then
  echo "Downloading Apache Maven $MAVEN_VERSION to $WRAPPER_DIR..."
  mkdir -p "$WRAPPER_DIR"
  TMPDIR=$(mktemp -d)
  trap 'rm -rf "$TMPDIR"' EXIT
  ARCHIVE="$TMPDIR/maven.tar.gz"
  URL="https://archive.apache.org/dist/maven/maven-3/$MAVEN_VERSION/binaries/apache-maven-$MAVEN_VERSION-bin.tar.gz"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$ARCHIVE" "$URL"
  else
    wget -qO "$ARCHIVE" "$URL"
  fi
  tar -xzf "$ARCHIVE" -C "$WRAPPER_DIR"
fi

exec "$MAVEN_DIR/bin/mvn" "$@"
